/*
 * boards/nrf52840dk_nrf52840.overlay
 *
 * Enable SPI3 (Arduino header) and attach the DWM3000EVB shield.
 *
 * nRF52840 DK Arduino header pin assignments:
 *   SPI3  SCK  = P1.15  (D13)  – from board pinctrl
 *   SPI3  MOSI = P1.13  (D11)  – from board pinctrl
 *   SPI3  MISO = P1.14  (D12)  – from board pinctrl
 *   DW3000 CS  = P1.12  (D10)
 *   DW3000 IRQ = P1.11  (D9)   – active high
 *   DW3000 RST = P1.10  (D8)   – active low
 */

&spi3 {
	status = "okay";

	cs-gpios = <&gpio1 12 GPIO_ACTIVE_LOW>;

	dw3000: dw3000@0 {
		compatible = "decawave,dw3000";
		reg = <0>;
		spi-max-frequency = <8000000>;  /* 8 MHz */
		int-gpios    = <&gpio1 11 GPIO_ACTIVE_HIGH>;
		reset-gpios  = <&gpio1 10 GPIO_ACTIVE_LOW>;
		wakeup-gpios = <&gpio1 8  GPIO_ACTIVE_HIGH>;
	};
};
